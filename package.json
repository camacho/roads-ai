{
  "name": "trestle",
  "description": "Local-only teaching harness workspace for constrained model assistance",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "docs": "scripts/markdown.ts",
    "docs:check": "scripts/markdown.ts --check",
    "format": "prettier --write . && format-package --write",
    "format:check": "prettier --check . && format-package --check",
    "lint": "eslint .",
    "prepare": "lefthook install",
    "release": "pnpm build && pnpm validate && changeset publish",
    "test": "pnpm -r test",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm docs:check && pnpm test"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "lefthook"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "format-package": "^8.0.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "markdown-magic": "4.11.0",
    "markdown-magic-engines": "2.1.0",
    "markdown-magic-package-scripts": "2.1.0",
    "markdown-magic-prettier": "3.1.0",
    "markdown-magic-subpackage-list": "2.1.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "catalog:"
  }
}
