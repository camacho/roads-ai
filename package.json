{
  "name": "roads-ai",
  "private": true,
  "description": "Local-only teaching harness workspace for constrained model assistance",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "typecheck": "tsc --noEmit",
    "docs": "node scripts/docs.mjs && prettier --write README.md docs/rfc-001.md packages/*/README.md",
    "docs:check": "pnpm run docs && git diff --exit-code -- README.md docs/rfc-001.md packages/*/README.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "ci:release": "node scripts/release.mjs && changeset tag && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "markdown-magic": "catalog:",
    "prettier": "catalog:",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "catalog:"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "lefthook"
    ]
  }
}
